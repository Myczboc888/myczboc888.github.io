body {
    margin: 0;
    font-family: Arial, sans-serif;
    text-align: center;
    color: white;

    background:
    linear-gradient(
        rgba(0,0,0,.5),
        rgba(0,0,0,.5)
    ),
    url("https://images.unsplash.com/photo-1448375240586-882707db888b");

    background-size: cover;
    min-height: 100vh;
}


button {
    margin: 5px;
    padding: 10px;
    border-radius: 15px;
    font-size: 16px;
    cursor: pointer;
}


#home {
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}


#home h1 {
    font-size: 50px;
}


#game {
    display: none;
}


#menu {
    display: none;
    background: #0009;
    padding: 15px;
    border-radius: 20px;
}


#map {
    display: grid;
    grid-template-columns: repeat(15, 35px);
    justify-content: center;
    gap: 2px;
    margin-top: 20px;
}


.cell {
    width: 35px;
    height: 35px;
    background: #45b945;
    border: 2px solid green;

    display: flex;
    align-items: center;
    justify-content: center;

    font-size: 22px;
}


#protect {
    font-size: 35px;
    color: #7cff7c;
}
